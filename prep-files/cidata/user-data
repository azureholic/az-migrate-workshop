#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: ubuntu-vm
    username: ubuntu
    password: $6$rounds=4096$saltsalt$3yQXbGBDJ7g5z8K9vN2x3L1mP4w5R6tY7u8I9o0P1a2S3d4F5g6H7j8K9l0Z1x2C3
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  packages:
    - openssh-server
    - linux-virtual
    - linux-tools-virtual
    - linux-cloud-tools-virtual
    - hyperv-daemons
  late-commands:
    - echo 'ubuntu ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/ubuntu
    - curtin in-target --target=/target -- chmod 440 /etc/sudoers.d/ubuntu